PORT=5000
MONGODB_URI=mongodb://localhost:27017/vaidya-assist
JWT_SECRET=your_jwt_secret_key
JWT_REFRESH_SECRET=your_refresh_secret_key
JWT_EXPIRE=1d
JWT_REFRESH_EXPIRE=7d
UPLOAD_PATH=uploads
NODE_ENV=development

# Google Sign-In. Obtain these from Google Cloud Console > APIs & Services >
# Credentials. Only GOOGLE_CLIENT_ID is required on the backend for ID token
# verification; the client ID is also needed in each frontend app.
GOOGLE_CLIENT_ID=your_google_client_id_here

# Optional service-to-service key. When set, internal endpoints like /api/medicines/low-stock
# require the X-Service-Key header from agent-service.
INTERNAL_SERVICE_KEY=your_service_key
